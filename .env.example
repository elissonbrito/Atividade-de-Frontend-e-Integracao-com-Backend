# ══════════════════════════════════════════════════════════
# Arquivo de exemplo de variáveis de ambiente
# Copie para .env e ajuste os valores antes de rodar
# ══════════════════════════════════════════════════════════

# ─── Geral ────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── JWT ──────────────────────────────────────────────────
# IMPORTANTE: troque por uma string aleatória forte em produção
JWT_SECRET=troque_esta_chave_por_algo_aleatorio_e_longo_minimo_32_chars
JWT_EXPIRES_IN=24h

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/api_db

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=api_users
POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgpassword

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:80

# ─── Frontend ────────────────────────────────────────────
# URL da API consumida pelo frontend
# Em Docker com Nginx proxy: /api → backend:3001
# Em desenvolvimento local: http://localhost:3001
VITE_API_URL=http://localhost:3001
